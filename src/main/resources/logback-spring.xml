<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <springProfile name="local">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) [traceId=%X{traceId}] - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO"><appender-ref ref="CONSOLE"/></root>
  </springProfile>

  <springProfile name="!local">
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>traceId</includeMdcKeyName>
        <includeMdcKeyName>userId</includeMdcKeyName>
        <includeMdcKeyName>requestUri</includeMdcKeyName>
        <includeMdcKeyName>method</includeMdcKeyName>
        <customFields>{"app":"pluto","module":"prestamos"}</customFields>
      </encoder>
    </appender>
    <root level="INFO"><appender-ref ref="JSON_CONSOLE"/></root>
  </springProfile>

</configuration>
